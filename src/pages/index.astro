---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Welcome" description="Demo App — a friendly landing page for learning web basics.">
  <section class="hero">
    <h1>Build faster, learn as you go</h1>
    <p class="hero__lead">
      Demo App is a pretend product for your course. This page is plain HTML in an Astro file — open
      <code>src/pages/index.astro</code> to see how it is written.
    </p>
    <p class="hero__actions">
      <a class="btn btn--primary" href="/features">See features</a>
      <a class="btn" href="/pricing">View pricing</a>
    </p>
  </section>

  <section class="block">
    <h2>Why this project?</h2>
    <p>
      You get a tiny real site: several routes, one shared layout, and simple CSS. Change the text,
      duplicate a page, or add a new link in the layout — small steps that teach how sites are
      structured.
    </p>
  </section>
</Layout>

<style>
  .hero {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .hero__lead {
    color: var(--muted);
    font-size: 1.0625rem;
    max-width: var(--max-width);
    margin: 0 0 1.5rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0;
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
  }

  .btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  .btn--primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #0a0e12;
  }

  .btn--primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    color: #0a0e12;
  }

  .block h2 {
    margin-top: 0;
    font-size: 1.25rem;
  }

  .block p {
    color: var(--muted);
    max-width: var(--max-width);
    margin: 0;
  }

  code {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
</style>
