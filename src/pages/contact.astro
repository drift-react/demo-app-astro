---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact us" description="Get in touch — static form for demo purposes.">
  <h1>Contact us</h1>
  <p class="intro">
    This form does not send data anywhere yet. When you add a backend or a form service, you will
    change the <code>action</code> attribute and add validation.
  </p>

  <form class="form">
    <label class="field">
      <span>Name</span>
      <input type="text" name="name" autocomplete="name" />
    </label>

    <label class="field">
      <span>Email</span>
      <input type="email" name="email" autocomplete="email" />
    </label>

    <label class="field">
      <span>Message</span>
      <textarea name="message" rows="5"></textarea>
    </label>

    <button class="submit" type="button">Send message (demo — not wired)</button>
  </form>
</Layout>

<style>
  h1 {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
  }

  .intro {
    color: var(--muted);
    margin: 0 0 1.5rem;
    max-width: 40rem;
  }

  code {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .form {
    max-width: 28rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .field span {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .field input,
  .field textarea {
    font: inherit;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 0.65rem;
  }

  .field input:focus,
  .field textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .submit {
    font: inherit;
    font-weight: 600;
    align-self: flex-start;
    padding: 0.55rem 1rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
  }

  .submit:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
