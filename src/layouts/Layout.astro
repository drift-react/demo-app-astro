---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const { title, description = "A small demo marketing site built with Astro." } = Astro.props;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/features", label: "Features" },
  { href: "/pricing", label: "Pricing" },
  { href: "/contact", label: "Contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · Demo App</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="logo" href="/">Demo App</a>
        <nav class="nav" aria-label="Main">
          <ul class="nav__list">
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} class:list={{ "nav__link--current": Astro.url.pathname === link.href }}>{link.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>Demo App — learning project. Not connected to a backend.</p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .site-header__inner {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .nav a {
    color: var(--muted);
    text-decoration: none;
  }

  .nav a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .nav__link--current {
    color: var(--text) !important;
    font-weight: 600;
  }

  .main {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 1.25rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.875rem;
  }

  .site-footer p {
    margin: 0;
    max-width: var(--wide);
    margin-inline: auto;
  }
</style>
